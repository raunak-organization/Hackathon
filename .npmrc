# Use pnpm workspace properly
node-linker=hoisted

# Faster installs
prefer-offline=true

# Strict dependency management (important)
strict-peer-dependencies=false
auto-install-peers=true

# Better DX
save-prefix=^

# Lockfile consistency
shared-workspace-lockfile=true

# Prevent accidental installs outside workspace
ignore-workspace-root-check=false

# Enable symlinks (important for monorepo packages)
link-workspace-packages=true

# Reduce noise
fund=false
audit=false